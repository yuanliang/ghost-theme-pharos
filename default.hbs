<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
    {{! Document Settings }}
    <meta http-equiv="Content-Type" content="text/html" charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />

    {{! Page Meta }}
    <title>{{meta_title}}</title>

    <link rel="shortcut icon" href="{{asset "/images/favicon.ico"}}">

    {{! Styles }}
    <link rel="stylesheet"  type="text/css" href="{{ asset "/stylesheets/font-awesome.min.css" }}" />
    <link rel="stylesheet"  type="text/css" href="{{ asset "/stylesheets/pharos.min.css" }}" />
    <link rel="stylesheet"  type="text/css" href="{{ asset "/stylesheets/pharos.runtime.css" }}" />
    <link rel="stylesheet"  type="text/css" href="{{ asset "/stylesheets/styles.css" }}" />

    {{! Responsive Meta Tags }}
    <meta name="HandheldFriendly" content="True" />
    <meta name="MobileOptimized" content="320" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {{#is "home,tag,author"}}
    {{ghost_head exclude="search,card_assets"}}
    {{else}}
    {{ghost_head exclude="search"}}
    {{/is}}
</head>
<body class="{{body_class}}">

    {{navigation}}

	{{{body}}}

    <script defer src="{{asset "/javascripts/pharos.js"}}"></script>
    {{ghost_foot}}
</body>
</html>
